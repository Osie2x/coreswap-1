# CORESWAP — LLM configuration
# Set ONE of the two keys below. GROQ_API_KEY takes priority if both are set.
#
# Free tier (recommended for local dev):
#   Sign up at https://console.groq.com → API Keys → Create key
GROQ_API_KEY=

# Paid (Anthropic):
#   Sign up at https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=
